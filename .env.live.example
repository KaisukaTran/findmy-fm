# Live instance environment — copy to the LIVE worktree as `.env`. NEVER commit real keys.
# Starts on Binance Spot TESTNET; switch to real funds only after live-readiness 1.4/1.5 land
# and you have validated end-to-end on testnet.

LIVE_TRADING=true
LIVE_USE_TESTNET=true

# Binance Spot TESTNET HMAC keys — generate at https://testnet.binance.vision
LIVE_API_KEY=
LIVE_API_SECRET=
LIVE_EXCHANGE=binance

# Keep the first real orders tiny.
LIVE_MAX_ORDER_NOTIONAL=25

# Isolation from the paper instance (also enforced by run_live.ps1):
DATABASE_URL=sqlite:///./data/live.db
SCHEDULER_LOCK_PORT=8802

# Optional: a separate Telegram bot/channel for the live instance so alerts don't mix with paper.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
