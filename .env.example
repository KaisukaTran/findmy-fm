# FINDMY-FM — Environment Configuration Example
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# All variables are optional for the local demo; secure values are required in prod.

# ===== Security =====
# Strong random string in production, e.g. `openssl rand -hex 32`
APP_SECRET_KEY=change_this_to_a_strong_random_string_in_production
# Shared key required in the X-API-Key header for write endpoints (when auth is on)
API_KEY=change_this_api_key
# Enforce the API key on mutation endpoints. Off by default for the local demo.
REQUIRE_AUTH=false
# Comma-separated allowed CORS origins
# CORS_ORIGINS=["http://localhost:8000"]

# ===== Database (single SQLite file by default) =====
# DATABASE_URL=sqlite:///./data/findmy.db

# ===== KSS / risk / pip sizing =====
PIP_MULTIPLIER=2.0
MAX_POSITION_SIZE_PCT=10.0
MAX_DAILY_LOSS_PCT=5.0
DEMO_ISOLATED_FUND=10000
ACCOUNT_EQUITY=10000

# ===== Paper execution simulation =====
TAKER_FEE_PCT=0.1
SLIPPAGE_PCT=0.05

# ===== Market data =====
PRICE_CACHE_TTL=60
LIVE_EXCHANGE=binance        # ccxt id for live prices
DATA_EXCHANGE=kraken         # ccxt id for backtest/scan history (no key): kraken / coinbase

# ===== Multi-agent scanner (the "options" you choose) =====
# Universe: a JSON list of always-evaluated symbols, plus auto-scanned top-N by volume
WATCHLIST=["BTC","ETH","SOL"]
SCAN_TOP_N=10
# Decision gates — a pair must clear ALL three to trade:
MIN_WIN_RATE=80              # backtested win-rate % (your ≥80% target, adjustable)
MIN_CONFIDENCE=70            # agent consensus %
DEADLINE_DAYS=30             # max days a session may wait for TP (≤30)
# Automation: false = semi-auto (you approve); true = full-auto (auto-approved)
AUTO_TRADE=false
# Parameters of sessions the scanner proposes
SCAN_DISTANCE_PCT=2.0
SCAN_TP_PCT=3.0
SCAN_MAX_WAVES=10
SCAN_FUND=1000
# Backtest window
BACKTEST_LOOKBACK_DAYS=180
BACKTEST_TIMEFRAME=1d
