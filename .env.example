# FINDMY-FM — Environment Configuration Example
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# All variables are optional for the local demo; secure values are required in prod.

# ===== Security =====
# Strong random string in production, e.g. `openssl rand -hex 32`
APP_SECRET_KEY=change_this_to_a_strong_random_string_in_production
# Shared key required in the X-API-Key header for write endpoints (when auth is on)
API_KEY=change_this_api_key
# Enforce the API key on mutation endpoints. Off by default for the local demo.
REQUIRE_AUTH=false
# Comma-separated allowed CORS origins
# CORS_ORIGINS=["http://localhost:8000"]

# ===== Database (single SQLite file by default) =====
# DATABASE_URL=sqlite:///./data/findmy.db

# ===== KSS / risk / pip sizing =====
PIP_MULTIPLIER=2.0
MAX_POSITION_SIZE_PCT=10.0
MAX_DAILY_LOSS_PCT=5.0
DEMO_ISOLATED_FUND=10000
ACCOUNT_EQUITY=10000

# ===== Paper execution simulation =====
TAKER_FEE_PCT=0.1
SLIPPAGE_PCT=0.05
# Profit floor = 2x this (Binance's highest spot taker fee). A session's TP% is
# raised to the floor so take-profit never fires on a gain below 2x the fee.
BINANCE_MAX_FEE_PCT=0.1

# ===== Market data =====
PRICE_CACHE_TTL=60
# Public ccxt ids, no API key. binance.com is geo/network-blocked here — use one of:
# kraken, okx, bybit, kucoin, binanceus, bitstamp, mexc, gate, cryptocom
LIVE_EXCHANGE=kraken         # ccxt id for live prices
DATA_EXCHANGE=kraken         # ccxt id for backtest/scan history

# ===== Multi-agent scanner (the "options" you choose) =====
# Universe: a JSON list of always-evaluated symbols, plus auto-scanned top-N by volume
WATCHLIST=["BTC","ETH","SOL"]
SCAN_TOP_N=10
# Decision gates — a pair must clear ALL three to trade:
MIN_WIN_RATE=80              # backtested win-rate % (your ≥80% target, adjustable)
MIN_CONFIDENCE=70            # agent consensus %
DEADLINE_DAYS=30             # max days a session may wait for TP (≤30)
# Automation: false = semi-auto (you approve); true = full-auto (auto-approved)
AUTO_TRADE=false
# Parameters of sessions the scanner proposes
SCAN_DISTANCE_PCT=2.0
SCAN_TP_PCT=3.0
SCAN_MAX_WAVES=10
SCAN_FUND=1000
# Backtest window
BACKTEST_LOOKBACK_DAYS=180
BACKTEST_TIMEFRAME=1d

# ===== v3: universe / loss-minimizing / cost / scheduler =====
MIN_QUOTE_VOLUME=1000000     # scan ALL pairs above this quote volume (liquidity floor)
SCAN_MAX_SYMBOLS=50          # hard cap on symbols per scan
MAX_LOSS_RATE=20             # max backtested loss-rate % to qualify
MIN_NET_EDGE=0.5            # min TP% above round-trip cost (micro-trade guard)
WALK_FORWARD_SPLIT=0.5       # metric computed on the out-of-sample tail
MAX_CONCURRENT_SESSIONS=5    # cap simultaneously active sessions
MAX_DEPLOYED_PCT=50          # cap total isolated funds as % of equity
SCAN_MIN_NOTIONAL=10         # skip dust micro-trades below this USD/wave
# Background scheduler (autonomy): off by default
SCHEDULER_ENABLED=false
SCAN_INTERVAL_MIN=15

# ===== v3.1: pending-queue auto-approval rule (off by default) =====
AUTOAPPROVE_ENABLED=false
AUTOAPPROVE_MAX_NOTIONAL=50      # auto-approve only orders with notional ≤ this USD
AUTOAPPROVE_SOURCES=["kss"]      # only these sources are eligible
AUTOAPPROVE_REQUIRE_NO_RISK=false

# ===== Phase A: full-auto master switch + safety (off by default) =====
# Master switch — when ON, scheduler + auto_trade + autoapprove run together.
# Persisted in the DB (runtime_config), so it survives restarts. Toggle live via
# POST /api/full-auto; this env value seeds the initial state.
FULL_AUTO=false
# KSS risk exits (per-session 0 = use these defaults). 0 disables the exit.
SL_PCT=8.0                       # session stop-loss: sell all if price ≤ avg×(1−SL%)
TRAILING_PCT=3.0                 # trailing stop: lock profit if price ≤ peak×(1−TRAIL%)
STOP_COOLDOWN_MIN=240            # after a stop-loss, don't re-open the same symbol for this long (0=off)
# Circuit breaker — freezes AUTO approvals (you can still approve by hand) when:
MAX_DRAWDOWN_PCT=15.0            # equity drawdown % exceeds this
DAILY_LOSS_HARD_PCT=5.0          # today's realized loss % exceeds this (hard stop)
MAX_CONSECUTIVE_LOSSES=4         # this many losing SELL fills in a row
BREAKER_COOLDOWN_MIN=60          # minutes frozen before it may auto-rearm

# ===== Phase B: AI Guardian (LLM veto) + Telegram remote-kill (off by default) =====
# Guardian: a Claude model reviews each auto-approval and may VETO unsafe orders.
# It can only block (never approve) — vetoed orders stay pending for human review.
GUARDIAN_ENABLED=false
ANTHROPIC_API_KEY=                # your Anthropic key; empty = Guardian no-op
GUARDIAN_MODEL=claude-haiku-4-5-20251001
GUARDIAN_MAX_TOKENS=1024
GUARDIAN_FAIL_OPEN=true           # on API error, allow (true) vs block (false) auto-approve
# Telegram: alerts + remote commands /status /pause /resume /freeze /reset.
# SECURITY: only TELEGRAM_CHAT_ID may send commands — leave it set, or the poller
# refuses to start (auth boundary). Get the token from @BotFather.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=               # bot token from @BotFather
TELEGRAM_CHAT_ID=                 # the only chat allowed to control the bot
TELEGRAM_POLL_INTERVAL=5

# ===== Phase C: per-pair hyperopt + ML win-rate (off by default) =====
# Hyperopt: grid-search the best KSS distance/tp/waves per pair (pure-Python,
# out-of-sample objective). Scanner falls back to the global SCAN_* when off.
HYPEROPT_ENABLED=false
HYPEROPT_TRIALS=50               # max param combos evaluated per pair
HYPEROPT_INTERVAL_HOURS=24       # background re-tune cadence
# ML: a learned win-rate model (pure-Python logistic) adds one weighted vote.
# Neutral (no influence) until trained with >= ML_MIN_SAMPLES samples.
ML_ENABLED=false
ML_MIN_SAMPLES=200
ML_WEIGHT=0.25                   # aggregator weight for the ML vote
ML_RETRAIN_HOURS=24
